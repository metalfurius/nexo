rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidRole(role) {
      return role in ['user', 'moderator', 'admin'];
    }

    function currentUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && currentUserRole() == 'admin';
    }

    function canCurateCatalog() {
      return isSignedIn() && currentUserRole() in ['admin', 'moderator'];
    }

    function isValidItemType(type) {
      return type in ['game', 'book', 'movie', 'series', 'anime', 'manga', 'manhwa', 'comic', 'other'];
    }

    function isValidProgressUnit(unit) {
      return unit in ['episodes', 'chapters', 'pages', 'hours', 'volumes', 'percent', 'items'];
    }

    function optionalString(field) {
      return !(field in request.resource.data) || request.resource.data[field] is string;
    }

    function optionalNumber(field) {
      return !(field in request.resource.data) || request.resource.data[field] is number;
    }

    function optionalStringList(field) {
      return !(field in request.resource.data) || request.resource.data[field] is list;
    }

    function isAutoCatalogCreate(publicItemId) {
      return isSignedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'title',
          'type',
          'description',
          'releaseYear',
          'progressTotal',
          'progressUnit',
          'genres',
          'tags',
          'moodTags',
          'searchAliases',
          'externalRefs',
          'posterUrl',
          'searchTokens',
          'canonicalKey',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy',
          'autoIngestedAt',
          'demandCount',
          'lastDemandAt'
        ])
        && request.resource.data.id == publicItemId
        && request.resource.data.title is string
        && isValidItemType(request.resource.data.type)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.autoIngestedAt is string
        && request.resource.data.demandCount == 1
        && request.resource.data.lastDemandAt == request.resource.data.autoIngestedAt
        && request.resource.data.canonicalKey is string
        && request.resource.data.searchTokens is list
        && request.resource.data.genres is list
        && request.resource.data.tags is list
        && request.resource.data.moodTags is list
        && request.resource.data.externalRefs is map
        && optionalString('description')
        && optionalNumber('releaseYear')
        && optionalNumber('progressTotal')
        && (!('progressUnit' in request.resource.data) || isValidProgressUnit(request.resource.data.progressUnit))
        && optionalStringList('searchAliases')
        && optionalString('posterUrl');
    }

    function isCatalogDemandUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'demandCount',
          'lastDemandAt',
          'updatedAt',
          'updatedBy',
          'description',
          'releaseYear',
          'progressTotal',
          'progressUnit',
          'posterUrl',
          'externalRefs'
        ])
        && (
          (resource.data.demandCount is number && request.resource.data.demandCount == resource.data.demandCount + 1) ||
          (!('demandCount' in resource.data) && request.resource.data.demandCount == 1)
        )
        && request.resource.data.lastDemandAt is string
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedAt']) || request.resource.data.updatedAt is string)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid)
        && isMissingStringFill('description')
        && isMissingStringFill('posterUrl')
        && isMissingNumberFill('releaseYear')
        && isMissingNumberFill('progressTotal')
        && isMissingProgressUnitFill()
        && isSafeExternalRefsMerge();
    }

    function isMissingStringFill(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field])
        || (!(field in resource.data) && request.resource.data[field] is string);
    }

    function isMissingNumberFill(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field])
        || (!(field in resource.data) && request.resource.data[field] is number);
    }

    function isMissingProgressUnitFill() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['progressUnit'])
        || (!('progressUnit' in resource.data) && isValidProgressUnit(request.resource.data.progressUnit));
    }

    function isSafeExternalRefsMerge() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['externalRefs'])
        || (
          resource.data.externalRefs is map
          && request.resource.data.externalRefs is map
          && request.resource.data.externalRefs.diff(resource.data.externalRefs).removedKeys().size() == 0
          && request.resource.data.externalRefs.diff(resource.data.externalRefs).changedKeys().size() == 0
        );
    }

    function isValidUserProfile(userId) {
      return request.resource.data.uid == userId
        && isValidRole(request.resource.data.role)
        && request.resource.data.keys().hasOnly([
          'uid',
          'role',
          'email',
          'displayName',
          'photoURL',
          'createdAt',
          'updatedAt',
          'lastSeenAt'
        ]);
    }

    function canCreateOwnProfile(userId) {
      return isOwner(userId)
        && request.resource.data.role == 'user'
        && isValidUserProfile(userId);
    }

    function canUpdateOwnProfile(userId) {
      return isOwner(userId)
        && resource.data.role == request.resource.data.role
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'displayName',
          'photoURL',
          'updatedAt',
          'lastSeenAt'
        ])
        && isValidUserProfile(userId);
    }

    function isUserCollection(collectionName) {
      return collectionName in [
        'items',
        'tags',
        'recommendationRuns',
        'activityEntries',
        'externalCandidates',
        'userSettings'
      ];
    }

    match /users/{userId}/{collectionName}/{documentId} {
      allow read, write: if isOwner(userId) && isUserCollection(collectionName);
    }

    match /publicItems/{publicItemId} {
      allow read: if isSignedIn();
      allow create: if canCurateCatalog() || isAutoCatalogCreate(publicItemId);
      allow update: if canCurateCatalog() || isCatalogDemandUpdate() || isAutoCatalogRevive(publicItemId);
      allow delete: if canCurateCatalog();
    }

    function isAutoCatalogRevive(publicItemId) {
      return isSignedIn()
        && ('archivedAt' in resource.data)
        && !('archivedAt' in request.resource.data)
        && isAutoCatalogCreate(publicItemId);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if canCreateOwnProfile(userId) || (isAdmin() && isValidUserProfile(userId));
      allow update: if canUpdateOwnProfile(userId) || (isAdmin() && isValidUserProfile(userId));
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
