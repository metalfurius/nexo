rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidRole(role) {
      return role in ['user', 'moderator', 'admin'];
    }

    function currentUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && currentUserRole() == 'admin';
    }

    function canCurateCatalog() {
      return isSignedIn() && currentUserRole() in ['admin', 'moderator'];
    }

    function isValidUserProfile(userId) {
      return request.resource.data.uid == userId
        && isValidRole(request.resource.data.role)
        && request.resource.data.keys().hasOnly([
          'uid',
          'role',
          'email',
          'displayName',
          'photoURL',
          'createdAt',
          'updatedAt',
          'lastSeenAt'
        ]);
    }

    function canCreateOwnProfile(userId) {
      return isOwner(userId)
        && request.resource.data.role == 'user'
        && isValidUserProfile(userId);
    }

    function canUpdateOwnProfile(userId) {
      return isOwner(userId)
        && resource.data.role == request.resource.data.role
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'displayName',
          'photoURL',
          'updatedAt',
          'lastSeenAt'
        ])
        && isValidUserProfile(userId);
    }

    function isUserCollection(collectionName) {
      return collectionName in [
        'items',
        'tags',
        'recommendationRuns',
        'activityEntries',
        'externalCandidates',
        'userSettings'
      ];
    }

    match /users/{userId}/{collectionName}/{documentId} {
      allow read, write: if isOwner(userId) && isUserCollection(collectionName);
    }

    match /publicItems/{publicItemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if canCurateCatalog();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if canCreateOwnProfile(userId) || (isAdmin() && isValidUserProfile(userId));
      allow update: if canUpdateOwnProfile(userId) || (isAdmin() && isValidUserProfile(userId));
      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
