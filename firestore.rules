rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAppCollection(collectionName) {
      return collectionName in [
        'items',
        'tags',
        'recommendationRuns',
        'externalCandidates',
        'userSettings'
      ];
    }

    match /{collectionName}/{documentId} {
      allow read, write: if isSignedIn() && isAppCollection(collectionName);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
