rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isUserCollection(collectionName) {
      return collectionName in [
        'items',
        'tags',
        'recommendationRuns',
        'externalCandidates',
        'userSettings'
      ];
    }

    match /users/{userId}/{collectionName}/{documentId} {
      allow read, write: if isOwner(userId) && isUserCollection(collectionName);
    }

    match /users/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
