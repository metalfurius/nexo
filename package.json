{
  "name": "nexo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost",
    "build": "tsc -b && vite build",
    "build:functions": "npm --prefix functions run build",
    "emulators": "firebase emulators:start",
    "catalog:normalize": "tsx scripts/importPublicCatalog.ts",
    "catalog:write": "tsx scripts/importPublicCatalog.ts --write",
    "import:markdown": "tsx scripts/importMarkdown.ts --source ../Listas --out seed/listas-import.json",
    "import:markdown:write": "tsx scripts/importMarkdown.ts --source ../Listas --out seed/listas-import.json --write",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "delete:legacy": "tsx scripts/deleteLegacyFirestore.ts",
    "check": "npm run lint && npm run test && npm run test:rules && npm run build",
    "check:functions": "npm run build:functions",
    "release:check": "npm run check && npm run test:e2e && npm audit --audit-level=high",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run src/firebase/firestoreRules.emulator.test.ts\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.19.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
